# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Client-Side Credentials (Vite Bundled) ---
# Paste keys here or in the AI Studio Secrets menu to pre-populate them.
VITE_XAI_KEY=""
VITE_WAVESPEED_KEY=""
VITE_ATLAS_KEY=""
VITE_CLOUDINARY_CLOUD=""
VITE_CLOUDINARY_PRESET=""
# --- Pre-Loaded LoRAs ---
# These will be loaded on the first boot if the user has no saved LoRAs.
VITE_LORA_1_URL=""
VITE_LORA_1_NAME=""
VITE_LORA_1_TRIGGER=""
VITE_LORA_1_BASE="Flux"

VITE_LORA_2_URL=""
VITE_LORA_2_NAME=""
VITE_LORA_2_TRIGGER=""
VITE_LORA_2_BASE="Flux"

VITE_LORA_3_URL=""
VITE_LORA_3_NAME=""
VITE_LORA_3_TRIGGER=""
VITE_LORA_3_BASE="Flux"
